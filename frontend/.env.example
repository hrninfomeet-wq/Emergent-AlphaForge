REACT_APP_BACKEND_URL=http://localhost:8001
ENABLE_HEALTH_CHECK=false
# Per-request timeout (ms) for heavy SYNCHRONOUS endpoints — backtest run, warehouse
# sync, data-hygiene scans, audits — that can take minutes on large date ranges.
# Ordinary calls keep the 60s default. Baked at build time (rebuild to change).
REACT_APP_API_TIMEOUT_LONG=600000
