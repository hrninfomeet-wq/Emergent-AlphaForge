# AlphaForge backend environment template
# Copy to backend/.env and fill in as needed. NEVER commit backend/.env.
#
# ============================================================================
# MongoDB
# ============================================================================
# Docker Compose: use `mongodb://mongo:27017`. Native (no Docker): use
# `mongodb://localhost:27017`.
MONGO_URL=mongodb://mongo:27017
DB_NAME=alphaforge
CORS_ORIGINS=http://localhost:3000

# ============================================================================
# Fernet (used to encrypt broker tokens in MongoDB)
# Generate a stable value before connecting Upstox:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ============================================================================
FERNET_KEY=

# ============================================================================
# Upstox — market data feed (spot + option candles)
# Register an app at https://developer.upstox.com/, then paste the client ID/secret.
# ============================================================================
UPSTOX_BASE_URL=https://api.upstox.com
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:8001/api/upstox/auth/callback
FRONTEND_POST_AUTH_URL=http://localhost:3000/warehouse

# ============================================================================
# AI strategy authoring (Strategy Library page: "Check Feasibility" + AI Generate)
# At least ONE of Gemini or Anthropic must be configured to use the AI wizard.
# Gemini API key: https://aistudio.google.com/apikey  (free tier available)
# Anthropic API key: https://console.anthropic.com/settings/keys
# ============================================================================
GEMINI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides (defaults are gemini-2.5-flash / gemini-2.5-pro and
# claude-sonnet-4-6 / claude-opus-4-8). Leave blank to use the shipped defaults.
GEMINI_FAST_MODEL=
GEMINI_POWERFUL_MODEL=
ANTHROPIC_FAST_MODEL=
ANTHROPIC_POWERFUL_MODEL=

# Optional: pin which provider the AI wizard uses when both keys are set.
# Values: anthropic | gemini. If unset, Anthropic is preferred (legacy behavior).
AI_PROVIDER=

# ============================================================================
# Live trading (Flattrade / Noren) — OFFLINE-FIRST
# The default posture is DRY-RUN: no real broker order is placed unless BOTH
# env flags below are 1 AND a per-deployment ARM is active within account caps.
# Leave these at 0 until you are actively armed for live execution.
# ============================================================================
LIVE_AUTOPLACE_ARMED=0
LIVE_GUARD_ARMED=0

# Flattrade broker credentials (only needed once you are running live).
# Ordinarily managed via the app's OAuth-style flow — most users leave these blank.
FLATTRADE_API_KEY=
FLATTRADE_API_SECRET=
FLATTRADE_USER_ID=
